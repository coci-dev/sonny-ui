{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["es2020"],
    "types": ["node"],
    "module": "commonjs",
    "target": "es2020",
    "declaration": true,
    "moduleResolution": "node",
    "outDir": "../../../dist/core/schematics",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
